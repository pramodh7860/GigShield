{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx ./src/index.ts",
    "build": "tsx ./build.ts",
    "prestart": "pnpm run build",
    "start": "node -r dotenv/config dist/index.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "express": "^5",
    "pino": "^9",
    "pino-http": "^10",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "esbuild": "^0.27.3",
    "pino-pretty": "^13",
    "tsx": "catalog:"
  }
}
